-- Task 3: Purchases

SELECT DISTINCT a.client_id
FROM account a
JOIN transaction t
ON a.id = t.account_id
WHERE t.amount < 5000
AND t.transaction_date >= CURRENT_DATE - INTERVAL '1 month';
